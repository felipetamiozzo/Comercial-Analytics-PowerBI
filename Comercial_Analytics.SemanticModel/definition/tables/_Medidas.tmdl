	measure 'Botao HTML Instrucao Navegacao' = ```
			
			"
			<style>
			    .pulse-indicator {
			        display: inline-flex;
			        align-items: center;
			        justify-content: center;
			        padding: 10px 24px;
			        border-radius: 30px;
			        background: rgba(5, 142, 217, 0.08); /* Fundo azul bem suave e transparente */
			        border: 1px solid rgba(5, 142, 217, 0.3);
			        color: #2708A0; /* Texto no azul escuro do seu tema */
			        font-family: 'Segoe UI', sans-serif;
			        font-size: 13px;
			        font-weight: 600;
			        letter-spacing: 0.5px;
			        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
			        animation: pulse 2s infinite;
			    }
			    
			    /* Efeito de pulsação suave ao redor do botão */
			    @keyframes pulse {
			        0% { box-shadow: 0 0 0 0 rgba(5, 142, 217, 0.4); }
			        70% { box-shadow: 0 0 0 10px rgba(5, 142, 217, 0); }
			        100% { box-shadow: 0 0 0 0 rgba(5, 142, 217, 0); }
			    }
			</style>
			
			<div style='width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;'>
			    <div class='pulse-indicator'>
			        
			        <!-- Ícone de Mão / Clique -->
			        <svg style='margin-right: 8px;' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='#058ED9' width='18' height='18'>
			            <path d='M9 11.24V7.5C9 6.12 10.12 5 11.5 5S14 6.12 14 7.5v3.74c1.21-.81 2-2.18 2-3.74C16 5.01 13.99 3 11.5 3S7 5.01 7 7.5c0 1.56.79 2.93 2 3.74zm9.84 4.63l-4.54-2.26c-.17-.07-.35-.11-.54-.11H13v-6c0-.83-.67-1.5-1.5-1.5S10 6.67 10 7.5v10.74l-3.43-.72c-.08-.01-.15-.03-.24-.03-.31 0-.59.13-.79.33l-.79.8 4.94 4.94c.27.27.65.44 1.04.44h6.79c.75 0 1.33-.55 1.44-1.28l.75-5.27c.01-.07.02-.14.02-.21 0-.62-.33-1.2-.85-1.47z'/>
			        </svg>
			        
			        Clique nos painéis acima para navegar
			        
			    </div>
			</div>
			"
			```
		displayFolder: UI e Design
		lineageTag: c24ad1d0-e0d0-4e44-a38e-048b0189303f


	measure 'Titulo HTML Capa' = ```
			
			"
			<div style='
			    width:100%;
			    height:100%;
			    display:flex;
			    flex-direction:column;
			    align-items:center;
			    justify-content:center;
			    font-family:Segoe UI, sans-serif;
			'>
			    <div style='
			        font-size: 56px;
			        font-weight: 800;
			        color: #2708A0;
			        letter-spacing: 1.5px;
			        text-shadow: 2px 4px 10px rgba(0,0,0,0.08);
			        text-align: center;
			        line-height: 1.1;
			        /* Efeito de Brilho Premium (Radial Gradient) */
			        background: radial-gradient(circle, rgba(255,255,255,0.85) 0%, rgba(255,255,255,0) 65%);
			        padding: 40px 120px;
			        margin-bottom: -32px; /* Compensa o padding para manter o subtítulo próximo */
			    '>
			        ANÁLISE COMERCIAL
			    </div>
			    
			    <div style='
			        font-size: 16px;
			        color: #058ED9;
			        font-weight: 600;
			        letter-spacing: 6px;
			        margin-top: 8px;
			        text-transform: uppercase;
			        position: relative;
			        z-index: 1; /* Garante que o subtítulo fique acima do brilho */
			    '>
			        Dashboard Gerencial
			    </div>
			    
			    <div style='
			        width: 100px;
			        height: 5px;
			        background: linear-gradient(90deg, #2708A0, #058ED9);

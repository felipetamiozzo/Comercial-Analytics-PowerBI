	measure 'Botao HTML Visao Operacional' = ```
			
			"
			<style>
			    .card-btn {
			        width: 100%; height: 100%; padding: 12px 10px; border-radius: 20px; box-sizing: border-box;
			        background: linear-gradient(135deg, #2708A0 0%, #058ED9 100%); font-family: 'Segoe UI', sans-serif;
			        position: relative; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
			        box-shadow: 0 4px 10px rgba(0,0,0,0.15), inset 0 2px 5px rgba(255,255,255,0.25); 
			        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
			    }
			    .card-btn:hover {
			        transform: scale(1.03) translateY(-3px); 
			        box-shadow: 0 12px 24px rgba(0,0,0,0.35), inset 0 4px 15px rgba(255,255,255,0.6); 
			        filter: brightness(1.15) saturate(1.3); 
			    }
			</style>
			
			<div class='card-btn'>
			    <div style='position:absolute; top:-12px; right:-12px; width:60px; height:60px; border-radius:50%; background:rgba(255,255,255,.1);'></div>
			    <div style='width:40px; height:40px; border-radius:50%; background:#2708A0; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,.25);'>
			        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white' width='22' height='22'>
			            <path d='M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z'/>
			        </svg>
			    </div>
			    <div style='display:flex; flex-direction:column; align-items:center; gap:2px;'>
			        <div style='font-size:12px; font-weight:700; color:#FFF; letter-spacing:.8px; text-align:center; white-space:nowrap;'>
			            VISÃO OPERACIONAL
			        </div>
			        <div style='font-size:11px; color:#E2E8F0; font-weight:400; opacity:0.9;'>

table _Medidas
	lineageTag: 13027f4a-71f7-4312-a3ed-ea5aa122dbdf

	measure 'Faturamento Total' = SUM(Vendas[ValorVenda])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: KPIs Principais
		lineageTag: f2abe05c-1703-40af-8f1b-adfec27878b9

	measure 'Volume de Vendas' = COUNTROWS(Vendas)
		formatString: 0
		displayFolder: KPIs Principais
		lineageTag: 077ff998-bddb-4caa-a3ca-4acaa9a8b462

	measure 'Ticket Medio' = DIVIDE([Faturamento Total], [Volume de Vendas],0)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: KPIs Principais
		lineageTag: 674d91a4-ca94-4d7a-84a6-d2f13023e1c2

	measure 'Custo Total' = SUM(Vendas[Custo])
		formatString: 0
		displayFolder: KPIs Principais
		lineageTag: 61e9d114-0b89-4080-baa0-5c37bcb91455

	measure 'Total Comissão' = SUM(Vendas[Valor Comissão ])
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		displayFolder: KPIs Principais
		lineageTag: 7ac49da6-4373-4c9e-8bf1-0e9d76c63fbe

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Lucro Líquido' = [Faturamento Total] - [Custo Total] - [Total Comissão]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: KPIs Principais
		lineageTag: eb508509-55b6-4c39-8a3a-7f707029c78b

	measure 'Margem de Lucro %' = DIVIDE([Lucro Líquido], [Faturamento Total],0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Variações e Percentuais
		lineageTag: d42dfb6d-b2e9-4c80-96f6-a9f310609b5e

	measure 'Card HTML Faturamento' =
			
			VAR Valor = FORMAT([Faturamento Total], "R$ #,##0.00")
			VAR Perc = [Var % Faturamento]
			
			VAR Indicador =
			IF(
			    ISBLANK(Perc),
			    "",
			    IF(
			        Perc >= 0,
			        "<div style='
			            color:#6EEB83;
			            font-size:12px;
			            font-weight:600;
			            margin-top:4px;
			            white-space:nowrap;
			        '>
			        ▲ " & FORMAT(Perc,"0.0%") & "
			        </div>",
			
			        "<div style='
			            color:#FF8A80;
			            font-size:12px;
			            font-weight:600;
			            margin-top:4px;
			            white-space:nowrap;
			        '>
			        ▼ " & FORMAT(ABS(Perc),"0.0%") & "
			        </div>"
			    )
			)
			
			RETURN
			"
			<div style='
			    width:100%;
			    height:100%;
			    border-radius:14px;
			    padding:14px 18px;
			    box-sizing:border-box;
			    background:linear-gradient(135deg, #2708A0 0%, #058ED9 100%);
			    font-family:Segoe UI, sans-serif;
			    position:relative;
			    overflow:hidden;
			    box-shadow: 0 6px 12px rgba(0,0,0,0.08);
			'>
			
			    <div style='
			        position:absolute;
			        top:-30px;
			        right:-20px;
			        width:90px;
			        height:90px;
			        border-radius:50%;
			        background:rgba(255,255,255,.1);
			    '></div>
			
			    <div style='
			        display:flex;
			        align-items:center;
			        justify-content:space-between;
			        height:100%;
			        position:relative;
			        z-index:1;
			    '>
			
			        <div>
			            <div style='
			                font-size:13px;
			                color:#EBEBEB;
			                margin-bottom:4px;
			            '>
			                Faturamento Total
			            </div>
			
			            <div style='
			                font-size:26px;
			                font-weight:700;
			                color:#FFFFFF;
			                line-height:28px;
			            '>
			                " & Valor & "
			            </div>
			
			            " & Indicador & "
			        </div>
			
			        <div style='
			            display:flex;
			            align-items:center;
			            justify-content:center;
			            width:44px;
			            height:44px;
			            border-radius:50%;
			            background-color:#FFFFFF;
			            box-shadow:0 4px 8px rgba(0,0,0,.15);
			        '>
			            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='#2708A0' width='28px' height='28px'>
			                <path d='M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z'/>
			            </svg>
			        </div>
			
			    </div>
			
			</div>
			"
		displayFolder: UI e Design
		lineageTag: b81e93d1-e85c-4859-ae38-3cbdeb262217

	measure 'Card HTML Volume Vendas' =
			
